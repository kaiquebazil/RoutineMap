// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // ou "mysql", "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  routines      Routine[]
  habits        Habit[]
  references    Reference[]
  dailyNotes    DailyNote[]
  weeklyReflections WeeklyReflection[]
}

model Routine {
  id          String    @id @default(cuid())
  title       String
  description String?
  color       String    @default("#7C3AED")
  icon        String    @default("calendar")
  energyLevel String    @default("medium") // high, medium, low
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  timeOfDay   String?
  daysOfWeek  String[]  // monday, tuesday, etc.
  priority    String    @default("medium") // high, medium, low
  sortOrder   Int       @default(0)
  routineId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  routine     Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
  completions TaskCompletion[]
}

model TaskCompletion {
  id        String   @id @default(cuid())
  taskId    String
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@unique([taskId, date])
}

model Habit {
  id        String       @id @default(cuid())
  name      String
  color     String       @default("#7C3AED")
  icon      String       @default("target")
  sortOrder Int          @default(0)
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   HabitEntry[]
}

model HabitEntry {
  id        String   @id @default(cuid())
  habitId   String
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
  
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  
  @@unique([habitId, date])
}

model Reference {
  id          String   @id @default(cuid())
  title       String
  url         String?
  description String?
  category    String   @default("other") // youtube, website, music, film, book, social, article, other
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyNote {
  id         String   @id @default(cuid())
  date       String   // YYYY-MM-DD
  intention  String?
  todos      String?
  notes      String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
}

model WeeklyReflection {
  id           String   @id @default(cuid())
  weekStart    String   // YYYY-MM-DD (Monday of the week)
  threeWords   String?
  proudMoments String?
  struggles    String?
  learned      String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, weekStart])
}